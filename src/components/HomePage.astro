---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from './Header.astro';
import Hero from './Hero.astro';
import MenuCard from './MenuCard.astro';
import Footer from './Footer.astro';

import CoffeeIcon from './icons/CoffeeIcon.astro';
import CroissantIcon from './icons/CroissantIcon.astro';
import LeafIcon from './icons/LeafIcon.astro';

import { ui, type Lang } from '../i18n/ui';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = ui[lang];
---
<BaseLayout title={t.title} lang={lang}>
  <Header lang={lang} />
  <main>
    <Hero lang={lang} />

    <section class="mx-auto max-w-6xl px-6 py-10">
  <div class="grid gap-6 md:grid-cols-3">
    
    <div class="rounded-3xl bg-foam p-8 ring-1 ring-coffee/10 transition-all duration-300 hover:-translate-y-2 hover:shadow-xl">
      <CoffeeIcon class="mb-4 h-14 w-14 text-terracotta" />
      <h3 class="mb-3 text-2xl font-black text-coffee">
        Café de especialidad
      </h3>
      <p class="leading-7 text-espresso/80">
        Seleccionamos cafés con carácter para ofrecer una experiencia auténtica en cada taza.
      </p>
    </div>

    <div class="rounded-3xl bg-foam p-8 ring-1 ring-coffee/10 transition-all duration-300 hover:-translate-y-2 hover:shadow-xl">
      <CroissantIcon class="mb-4 h-14 w-14 text-terracotta" />
      <h3 class="mb-3 text-2xl font-black text-coffee">
        Desayunos artesanales
      </h3>
      <p class="leading-7 text-espresso/80">
        Bollería, tostadas y opciones sencillas preparadas para acompañar tu café.
      </p>
    </div>

    <div class="rounded-3xl bg-foam p-8 ring-1 ring-coffee/10 transition-all duration-300 hover:-translate-y-2 hover:shadow-xl">
      <LeafIcon class="mb-4 h-14 w-14 text-terracotta" />
      <h3 class="mb-3 text-2xl font-black text-coffee">
        Producto local
      </h3>
      <p class="leading-7 text-espresso/80">
        Apostamos por ingredientes cercanos y de calidad para cuidar cada detalle.
      </p>
    </div>

  </div>
</section>

    <section id="story" class="mx-auto max-w-6xl px-6 py-16">
      <div class="rounded-[2rem] bg-coffee p-8 text-foam md:p-12">
        <p class="mb-3 text-sm font-bold uppercase tracking-[0.25em] text-terracotta">Café Alejandro</p>
        <h2 class="mb-4 text-4xl font-black">{t.storyTitle}</h2>
        <p class="max-w-3xl text-lg leading-8 text-foam/85">{t.storyText}</p>
      </div>
    </section>

    <section id="menu" class="mx-auto max-w-6xl px-6 py-16">
  <div class="mb-10 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
    <div>
      <p class="mb-3 text-sm font-bold uppercase tracking-[0.25em] text-terracotta">Nuestra carta</p>
      <h2 class="text-4xl font-black text-coffee">{t.menuTitle}</h2>
    </div>
    <p class="max-w-md text-espresso/75">
      Una selección sencilla de cafés, desayunos y dulces pensada para acompañar cualquier momento del día.
    </p>
  </div>

  <div class="grid gap-6 md:grid-cols-3">
    <div class="rounded-3xl bg-foam p-8 ring-1 ring-coffee/10">
      <h3 class="mb-6 text-2xl font-black text-coffee">Cafés</h3>

      <div class="space-y-5">
        <div class="flex justify-between gap-4 border-b border-coffee/10 pb-4">
          <div>
            <p class="font-bold text-espresso">Espresso</p>
            <p class="text-sm text-espresso/65">Intenso, corto y aromático.</p>
          </div>
          <p class="font-black text-coffee">1,80€</p>
        </div>

        <div class="flex justify-between gap-4 border-b border-coffee/10 pb-4">
          <div>
            <p class="font-bold text-espresso">Cappuccino</p>
            <p class="text-sm text-espresso/65">Café, leche cremosa y espuma.</p>
          </div>
          <p class="font-black text-coffee">2,90€</p>
        </div>

        <div class="flex justify-between gap-4">
          <div>
            <p class="font-bold text-espresso">Latte</p>
            <p class="text-sm text-espresso/65">Suave, cremoso y equilibrado.</p>
          </div>
          <p class="font-black text-coffee">3,20€</p>
        </div>
      </div>
    </div>

    <div class="rounded-3xl bg-foam p-8 ring-1 ring-coffee/10">
      <h3 class="mb-6 text-2xl font-black text-coffee">Desayunos</h3>

      <div class="space-y-5">
        <div class="flex justify-between gap-4 border-b border-coffee/10 pb-4">
          <div>
            <p class="font-bold text-espresso">Tostada con tomate</p>
            <p class="text-sm text-espresso/65">Pan crujiente, tomate y aceite.</p>
          </div>
          <p class="font-black text-coffee">3,50€</p>
        </div>

        <div class="flex justify-between gap-4 border-b border-coffee/10 pb-4">
          <div>
            <p class="font-bold text-espresso">Bocadillo pequeño</p>
            <p class="text-sm text-espresso/65">Opción sencilla para media mañana.</p>
          </div>
          <p class="font-black text-coffee">4,20€</p>
        </div>

        <div class="flex justify-between gap-4">
          <div>
            <p class="font-bold text-espresso">Yogur con fruta</p>
            <p class="text-sm text-espresso/65">Ligero, fresco y natural.</p>
          </div>
          <p class="font-black text-coffee">4,80€</p>
        </div>
      </div>
    </div>

    <div class="rounded-3xl bg-foam p-8 ring-1 ring-coffee/10">
      <h3 class="mb-6 text-2xl font-black text-coffee">Dulces</h3>

      <div class="space-y-5">
        <div class="flex justify-between gap-4 border-b border-coffee/10 pb-4">
          <div>
            <p class="font-bold text-espresso">Croissant</p>
            <p class="text-sm text-espresso/65">Clásico, dorado y mantecoso.</p>
          </div>
          <p class="font-black text-coffee">1,90€</p>
        </div>

        <div class="flex justify-between gap-4 border-b border-coffee/10 pb-4">
          <div>
            <p class="font-bold text-espresso">Tarta casera</p>
            <p class="text-sm text-espresso/65">Pregunta por la tarta del día.</p>
          </div>
          <p class="font-black text-coffee">4,50€</p>
        </div>

        <div class="flex justify-between gap-4">
          <div>
            <p class="font-bold text-espresso">Cookie artesanal</p>
            <p class="text-sm text-espresso/65">Crujiente por fuera, tierna por dentro.</p>
          </div>
          <p class="font-black text-coffee">2,50€</p>
        </div>
      </div>
    </div>
  </div>
</section>

    <section id="hours" class="mx-auto max-w-6xl px-6 py-16">
      <div class="grid gap-6 md:grid-cols-2">
        <div class="rounded-3xl bg-foam p-8 ring-1 ring-coffee/10">
          <h2 class="mb-4 text-3xl font-black text-coffee">{t.hoursTitle}</h2>
          <p class="text-lg text-espresso/80">{t.hoursText}</p>
        </div>
        <div id="contact" class="rounded-3xl bg-foam p-8 ring-1 ring-coffee/10">
          <h2 class="mb-4 text-3xl font-black text-coffee">{t.contactTitle}</h2>
          <p class="text-lg text-espresso/80">{t.contactText}</p>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
