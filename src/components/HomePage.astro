---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from './Header.astro';
import Hero from './Hero.astro';
import MenuCard from './MenuCard.astro';
import Footer from './Footer.astro';
import { ui, type Lang } from '../i18n/ui';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = ui[lang];
---
<BaseLayout title={t.title} lang={lang}>
  <Header lang={lang} />
  <main>
    <Hero lang={lang} />

    <section id="story" class="mx-auto max-w-6xl px-6 py-16">
      <div class="rounded-[2rem] bg-coffee p-8 text-foam md:p-12">
        <p class="mb-3 text-sm font-bold uppercase tracking-[0.25em] text-terracotta">Café Alejandro</p>
        <h2 class="mb-4 text-4xl font-black">{t.storyTitle}</h2>
        <p class="max-w-3xl text-lg leading-8 text-foam/85">{t.storyText}</p>
      </div>
    </section>

    <section id="menu" class="mx-auto max-w-6xl px-6 py-16">
      <h2 class="mb-8 text-4xl font-black text-coffee">{t.menuTitle}</h2>
      <div class="grid gap-6 md:grid-cols-3">
        <MenuCard title={t.coffee} text="Espresso, latte, cappuccino y café de filtro." />
        <MenuCard title={t.breakfast} text="Tostadas, bocadillos, fruta y opciones sencillas para empezar bien." />
        <MenuCard title={t.sweets} text="Croissants, tartas caseras y pequeños caprichos para acompañar el café." />
      </div>
    </section>

    <section id="hours" class="mx-auto max-w-6xl px-6 py-16">
      <div class="grid gap-6 md:grid-cols-2">
        <div class="rounded-3xl bg-foam p-8 ring-1 ring-coffee/10">
          <h2 class="mb-4 text-3xl font-black text-coffee">{t.hoursTitle}</h2>
          <p class="text-lg text-espresso/80">{t.hoursText}</p>
        </div>
        <div id="contact" class="rounded-3xl bg-foam p-8 ring-1 ring-coffee/10">
          <h2 class="mb-4 text-3xl font-black text-coffee">{t.contactTitle}</h2>
          <p class="text-lg text-espresso/80">{t.contactText}</p>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
