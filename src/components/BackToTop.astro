---
import ArrowUpIcon from './icons/ArrowUpIcon.astro';
---

<button
  id="backToTop"
  aria-label="Back to top"
  class="fixed bottom-6 right-6 z-50 flex h-12 w-12 translate-y-4 items-center justify-center rounded-full bg-coffee text-xl text-foam opacity-0 shadow-lg transition-all duration-300 hover:bg-terracotta"
>
  <ArrowUpIcon class="h-6 w-6" />
</button>

<script>
  const button = document.getElementById("backToTop");

  function toggleButton() {
    if (!button) return;

    if (window.scrollY > 300) {
      button.classList.remove("opacity-0", "translate-y-4", "pointer-events-none");
      button.classList.add("opacity-100", "translate-y-0");
    } else {
      button.classList.remove("opacity-100", "translate-y-0");
      button.classList.add("opacity-0", "translate-y-4", "pointer-events-none");
    }
  }

  window.addEventListener("scroll", toggleButton);

  button?.addEventListener("click", () => {
    window.scrollTo({
      top: 0,
      behavior: "smooth",
    });
  });

  toggleButton();
</script>