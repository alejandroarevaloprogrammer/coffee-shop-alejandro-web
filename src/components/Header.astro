---
import LanguageSwitcher from './LanguageSwitcher.astro';
import LogoCoffeeIcon from './icons/LogoCoffeeIcon.astro';

import { ui, type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = ui[lang];
---

<header class="mx-auto flex max-w-6xl items-center justify-between px-6 py-6">
  <a
    href={`/${lang}`}
    class="group flex items-center gap-3 transition-opacity hover:opacity-90"
  >
    <LogoCoffeeIcon class="h-12 w-12 text-terracotta transition-transform duration-300 group-hover:rotate-6 group-hover:scale-110" />

    <div class="leading-none">
      <p class="text-xl font-black tracking-tight text-coffee">
        CAFÉ ALEJANDRO
      </p>
    </div>
  </a>

  <nav class="hidden gap-6 text-sm font-medium text-espresso md:flex">
  <a href="#menu" class="group relative transition-colors duration-300 hover:text-terracotta">
    {t.navMenu}
    <span class="absolute -bottom-1 left-0 h-0.5 w-0 bg-terracotta transition-all duration-300 group-hover:w-full"></span>
  </a>

  <a href="#story" class="group relative transition-colors duration-300 hover:text-terracotta">
    {t.navStory}
    <span class="absolute -bottom-1 left-0 h-0.5 w-0 bg-terracotta transition-all duration-300 group-hover:w-full"></span>
  </a>

  <a href="#hours" class="group relative transition-colors duration-300 hover:text-terracotta">
    {t.navHours}
    <span class="absolute -bottom-1 left-0 h-0.5 w-0 bg-terracotta transition-all duration-300 group-hover:w-full"></span>
  </a>

  <a href="#contact" class="group relative transition-colors duration-300 hover:text-terracotta">
    {t.navContact}
    <span class="absolute -bottom-1 left-0 h-0.5 w-0 bg-terracotta transition-all duration-300 group-hover:w-full"></span>
  </a>
</nav>

  <LanguageSwitcher currentLang={lang} />
</header>