---
import LanguageSwitcher from './LanguageSwitcher.astro';
import LogoCoffeeIcon from './icons/LogoCoffeeIcon.astro';

import { ui, type Lang } from '../i18n/ui';

interface Props { lang: Lang; }

const { lang } = Astro.props;
const t = ui[lang];
---
<header class="mx-auto flex max-w-6xl items-center justify-between px-6 py-6">
  <a
  href={`/${lang}`}
  class="flex items-center gap-3 transition-opacity hover:opacity-90">


  <LogoCoffeeIcon class="h-12 w-12 text-terracotta" />

  <div class="leading-none">
    <p class="text-xl font-black tracking-tight text-coffee">
      CAFÉ ALEJANDRO
    </p>
  </div>
</a>
  <nav class="hidden gap-6 text-sm font-medium text-espresso md:flex">
    <a href="#menu" class="hover:text-terracotta">{t.navMenu}</a>
    <a href="#story" class="hover:text-terracotta">{t.navStory}</a>
    <a href="#hours" class="hover:text-terracotta">{t.navHours}</a>
    <a href="#contact" class="hover:text-terracotta">{t.navContact}</a>
  </nav>
  <LanguageSwitcher currentLang={lang} />
</header>
