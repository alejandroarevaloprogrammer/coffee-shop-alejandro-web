---
import LogoCoffeeIcon from './icons/LogoCoffeeIcon.astro';
import { ui, type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = ui[lang];

const currentYear = new Date().getFullYear();
---

<footer class="mt-20 border-t border-coffee/10">
  <div class="mx-auto max-w-6xl px-6 py-16">
    <div class="flex flex-col items-center text-center">
      <a
        href={`/${lang}`}
        class="group flex flex-col items-center transition-opacity hover:opacity-90"
      >
        <LogoCoffeeIcon class="mb-4 h-12 w-12 text-terracotta transition-transform duration-300 group-hover:rotate-6 group-hover:scale-110" />

        <h3 class="text-2xl font-black tracking-tight text-coffee">
          CAFÉ ALEJANDRO
        </h3>

        <p class="mt-2 text-espresso/70">
          {t.eyebrow}
        </p>
      </a>

      <nav class="mt-6 flex flex-wrap justify-center gap-6 text-sm font-medium">
        <a href="#menu" class="transition-colors duration-500 hover:text-terracotta">
          {t.navMenu}
        </a>

        <a href="#story" class="transition-colors duration-500 hover:text-terracotta">
          {t.navStory}
        </a>

        <a href="#hours" class="transition-colors duration-500 hover:text-terracotta">
          {t.navHours}
        </a>

        <a href="#contact" class="transition-colors duration-500 hover:text-terracotta">
          {t.navContact}
        </a>
      </nav>

      <div class="mt-8 text-sm text-espresso/60">
        © {currentYear} Café Alejandro
      </div>
    </div>
  </div>
</footer>