---
import '../styles.css';
import type { Lang } from '../i18n/ui';

interface Props {
  title: string;
  lang: Lang;
}

const { title, lang } = Astro.props;
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Café Alejandro: café artesanal, desayuno y brunch." />
    <title>{title}</title>
  </head>
  <body class="font-sans antialiased">
    <slot />
  </body>
</html>
